# ==============================================================================
# 全局配置（所有 step 可共享）
# ==============================================================================
global:
  # 要执行的步骤
  steps_to_run:
    # - download
    # - selectors
    # - collect
    # - find_range
    # - find_range_full
    # - test_range
    - generate_info
    # - pack_csv
    # - build_sql
    # - update_rule_obs  
    # - update_rule_api

  # 日志模式：
  # - normal：尽量保持你原来“console log/打印”的格式与信息量（默认）
  # - debug ：输出更详细信息（包含更多上下文、更多步骤细节、更完整异常栈等）
  log_mode: "normal"   # "normal" | "debug"

  # 全局 dry-run（演练模式）
  # 说明：若为 true，runner 会尽量要求各 step 不产生破坏性动作；
  #       同时各 step 仍保留自己的 DRY_RUN 配置（后续代码会做 OR 合并）
  dry_run: false

  # 是否允许继续执行后续 step（全局容错）
  # - false：任一步失败立即中断（推荐，符合你“及时上报和中断流程”）
  # - true ：记录错误并继续（仅调试时可能用）
  continue_on_error: false


# ==============================================================================
# Step: download（负责：下载/搬运/合并/分组；并自动发现构型）
# ==============================================================================
download:
  # 当前使用哪个预设（dev/prod）
  # 说明：
  # - bucket 从 global.presets.<preset>.obs_bucket 读取
  # - 你也可以把 current_preset 固定为 prod，并且只改 global.presets 中的 bucket/url
  current_preset: "prod"

  # OBS 前缀（末尾带 / 不带都行）
  obs_prefix: "data-collector-svc/collect/"

  # obsutil 并行参数：用于提升下载速度
  parallel: 16
  jobs: 16

  # obsutil 可执行文件：留空表示用 PATH 里的 obsutil
  # e.g. "C:\\path\\to\\obsutil.exe"
  obsutil_exe: null

  # 开启后：不重新下载，只做“搬运/合并 + 分组 + 写 log”
  # 说明：适合你已经有 collect 落盘，想重新分组/刷新 obs_download 的场景
  skip_download: false

  # True：完全覆盖过去的 obs_download（不考虑已存在内容，保证全量更新）
  # 说明：你之前提到的“完全覆盖 collect 和 obs_download”的核心开关之一
  full_refresh: true

  # 是否只演练（不实际移动/不实际下载）
  # 说明：用于安全验证逻辑；如果 global.dry_run=true，这里也会被视为 true（后续代码实现）
  dry_run: false

  # 是否启用 CSV 读取模式
  # - false: 使用 obs_prefix 单一路径下载（原模式）
  # - true : 读取 CSV，多路径下载（taskid list 模式）
  csv_mode: false

  # CSV 文件路径（相对 repo_root 或绝对路径都可）
  csv_path: "task_id.csv"

  # CSV 中 taskid 所在列名（支持带表头的 CSV）
  # 如果你的 CSV 没有表头，可以设为 null，并使用 csv_col_index
  csv_col_name: "task_id"

  # CSV 列索引（0-based），仅当 csv_col_name 为 null 时生效
  csv_col_index: 0

  # 是否跳过首行（仅当你没有表头但第一行是说明时用）
  csv_skip_header: false

  # 拼接方式：obs_prefix(作为 base) + taskid + "/"
  # true: 每行视作 taskid，拼成 data-collector-svc/collect/<taskid>/
  # false: 每行视作完整 prefix（更通用，但你现在主要用 true）
  csv_rows_are_taskid: true

# ==============================================================================
# Step: selectors（负责：生成 selector 列表 + 过滤规则）
# ==============================================================================
selectors:
  # 并集模式
  use_union_of_all_samples: true

  # 并集模式下的最小样本数过滤
  enable_union_min_sample_filter: ture
  
  # 全局默认阈值：字段至少在 N 个样本中出现才保留
  union_min_sample_count: 2
  
  # 按构型覆盖阈值（可选）
  # union_min_sample_count_by_model:
    # "构型": 10

  # 随机一致性检查（只在 generate_selectors_txt 时触发）
  enable_random_consistency_check: false

  # 随机抽样“不同 taskid 目录”的数量（每个 task 取 1 个 json）
  consistency_sample_tasks: 10000

  # 随机种子：保证可复现（不想固定就设为 null）
  consistency_random_seed: 0

  # mismatch 时最多展示多少条差异 selector（避免刷屏）
  consistency_diff_preview: 5

# ==============================================================================
# Step: collect（负责：从 json 中按 selector 收集值，输出 values.csv）
# ==============================================================================
collect:
  # 是否写 CSV 表头
  csv_write_header: true

  # 严格模式
  # - true ：遇到错误直接抛异常（runner 捕获后中断）
  # - false：失败返回 None 或跳过（按你原逻辑）
  strict_mode: false

# ==============================================================================
# Step: find_range（负责：根据 values.csv 估计区间，输出 ranges.csv）
# ==============================================================================
find_range:
  method: "cover"          # "iqr" / "mad" / "cover"
  iqr_k: 1.5
  mad_z: 3.0
  cover_pct: 0.95

# ==============================================================================
# Step: find_range_full
# ==============================================================================

# ==============================================================================
# Step: test_range（负责：区间命中检测，写回 ranges.csv 并输出统计）
# ==============================================================================
test_range:
  treat_nan_as_fail: true
  fields_mode: "range_only"

  missing_value_col_is_fail: true
  missing_range_is_fail: false

  show_top_fields: true
  top_n_fields: 5

  show_fail_details: true
  max_fail_details: 1

# ==============================================================================
# Step: generate_info（负责：从 JSON 提取元数据信息，生成 info.csv）
# ==============================================================================
generate_info:

  # 额外列配置（可选）
  # extra_columns:
  #   - column_name: "joint_action_name"  # CSV 列名
  #     selector: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<data_info>.<joint_info>.<action/robot>.<name>"
  #     models: ["COBOTMAGICV2.0", "GR2"]  # 可选，为空或省略则应用到所有构型
  #   - column_name: "manufacturer"
  #     selector: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<equipment_info>.<manufacturer>"
  #     # models 未指定 = 应用到所有构型
  extra_columns: []


# ==============================================================================
# Step: pack_csv（负责：把 ranges.csv 转成 ranges.txt）
# ==============================================================================

# ==============================================================================
# Step: build_sql（负责：把 ranges.txt 生成 update_rule_config.sql）
# ==============================================================================
build_sql:
  sql_dirname: "sql_output"
  sql_filename: "update_rule_config.sql"
  csv_output_dirname: "csv_output"
  fail_if_missing: true

# ==============================================================================
# Step: update_rule_obs（负责：把 ranges.csv 上传到 OBS 固定路径，不覆盖）
# ==============================================================================
update_rule_obs:
  # dev / prod（bucket 从 global.presets.<preset>.obs_bucket 取）
  current_preset: "prod"

# ==============================================================================
# Step: update_rule_api（负责：调用接口更新规则）
# ==============================================================================
update_rule_api:
  # 当前使用哪个预设（dev 或 prod）
  current_preset: "prod"

  # header 名：按你接口要求是 accesstoken
  access_token: "eyJhbGciOiJSUzI1NiIsImtpZCI6ImRhdGEtY29sbGVjdG9yLWNlcnQiLCJ0eXAiOiJKV1QifQ..ne9-ucYefAD62Njv6kBJu3s4zC2Mr8afyetqadKklu6vJlrVIHoWdRh_4B0Ct6Hi_avhCQQDBOc80lyyIBaq7ud84BeHP5maUjfPiv3DmBQx-fMwhe9gzAyYxJfAE4wtmnTuoS0Ga9WwXQHJyhEQHJOaGJfFwKttIlNrMKd4Eoq6wOU5hnf3Wo3yAHh1ClHdYGR8kVH03svoC2caxp4_x44ggxjo43WBqbmNhyoGbrTPKOApKNu-x5ktaNqyL8fJfT69X4BEcrLBHp3dUcfrcHsDkkNqxqvYogNHWN20-WtVr8bn66uCp-iJ6h6ledkSiq7e14MBf5CNCyOmW2AnWZ8LOOSGWpR0_F4dpt-GxzNOIZKeQKpQHIR9BrcatNzCXx_m4sk-5PJUgMl4LUgAXdhFMTHlZGoF5JgDAPC2W5z767752nuoJ1hPLkUmyAQKpzCt7bJvJaYjGhUFuT5FPPoKxa2brw3BTwbWQcjuCCfgX9-7uJbKSkwKpcWRafT85jfvEHzCI18wD333aI36CtVL9rZkyRAQdzW9k2LEPjijaDpTtqgteuKDRZZttNIgGie_vZKIoaTiUx7W0pa3EtKq7CAFcvovjuoxZpbiRabNNGlyfR9l_soGkJ9OECuqNaUH6pTo2mBqv9HWwjN6FLIg4hLvXv_iuyyOHAKE3hE"
