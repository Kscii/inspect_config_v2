# ==============================================================================
# 全局配置（所有 step 可共享）
# ==============================================================================
global:
  # 要执行的步骤
  steps_to_run:
    # - download
    # - selectors
    # - collect
    # - find_range
    # - find_range_full
    # - test_range
    # - generate_db_csv
    # - import_db
    - visualize_db
    # - pack_csv
    # - build_sql
    # - update_rule_obs  
    # - update_rule_api

  # 日志模式：
  # - normal：尽量保持你原来“console log/打印”的格式与信息量（默认）
  # - debug ：输出更详细信息（包含更多上下文、更多步骤细节、更完整异常栈等）
  log_mode: "normal"   # "normal" | "debug"

  # 全局 dry-run（演练模式）
  # 说明：若为 true，runner 会尽量要求各 step 不产生破坏性动作；
  #       同时各 step 仍保留自己的 DRY_RUN 配置（后续代码会做 OR 合并）
  dry_run: false

  # 是否允许继续执行后续 step（全局容错）
  # - false：任一步失败立即中断（推荐，符合你“及时上报和中断流程”）
  # - true ：记录错误并继续（仅调试时可能用）
  continue_on_error: false


# ==============================================================================
# Step: download（负责：下载/搬运/合并/分组；并自动发现构型）
# ==============================================================================
download:
  # 当前使用哪个预设（dev/prod）
  # 说明：
  # - bucket 从 global.presets.<preset>.obs_bucket 读取
  # - 你也可以把 current_preset 固定为 prod，并且只改 global.presets 中的 bucket/url
  current_preset: "dev"

  # OBS 前缀（末尾带 / 不带都行）
  obs_prefix: "data-collector-svc/collect/"

  # obsutil 并行参数：用于提升下载速度
  parallel: 16
  jobs: 16

  # obsutil 可执行文件：留空表示用 PATH 里的 obsutil
  # e.g. "C:\\path\\to\\obsutil.exe"
  obsutil_exe: null

  # 开启后：不重新下载，只做“搬运/合并 + 分组 + 写 log”
  # 说明：适合你已经有 collect 落盘，想重新分组/刷新 obs_download 的场景
  skip_download: false

  # True：完全覆盖过去的 obs_download（不考虑已存在内容，保证全量更新）
  # 说明：你之前提到的“完全覆盖 collect 和 obs_download”的核心开关之一
  full_refresh: true

  # 是否只演练（不实际移动/不实际下载）
  # 说明：用于安全验证逻辑；如果 global.dry_run=true，这里也会被视为 true（后续代码实现）
  dry_run: false

  # 是否启用 CSV 读取模式
  # - false: 使用 obs_prefix 单一路径下载（原模式）
  # - true : 读取 CSV，多路径下载（taskid list 模式）
  csv_mode: false

  # CSV 文件路径（相对 repo_root 或绝对路径都可）
  csv_path: "task_id.csv"

  # CSV 中 taskid 所在列名（支持带表头的 CSV）
  # 如果你的 CSV 没有表头，可以设为 null，并使用 csv_col_index
  csv_col_name: "task_id"

  # CSV 列索引（0-based），仅当 csv_col_name 为 null 时生效
  csv_col_index: 0

  # 是否跳过首行（仅当你没有表头但第一行是说明时用）
  csv_skip_header: false

  # 拼接方式：obs_prefix(作为 base) + taskid + "/"
  # true: 每行视作 taskid，拼成 data-collector-svc/collect/<taskid>/
  # false: 每行视作完整 prefix（更通用，但你现在主要用 true）
  csv_rows_are_taskid: true

# ==============================================================================
# Step: selectors（负责：生成 selector 列表 + 过滤规则）
# ==============================================================================
selectors:
  # 并集模式
  use_union_of_all_samples: true

  # 并集模式下的最小样本数过滤
  enable_union_min_sample_filter: ture
  
  # 全局默认阈值：字段至少在 N 个样本中出现才保留
  union_min_sample_count: 2
  
  # 按构型覆盖阈值（可选）
  # union_min_sample_count_by_model:
    # "构型": 10

  # 随机一致性检查（只在 generate_selectors_txt 时触发）
  enable_random_consistency_check: false

  # 随机抽样“不同 taskid 目录”的数量（每个 task 取 1 个 json）
  consistency_sample_tasks: 10000

  # 随机种子：保证可复现（不想固定就设为 null）
  consistency_random_seed: 0

  # mismatch 时最多展示多少条差异 selector（避免刷屏）
  consistency_diff_preview: 5

# ==============================================================================
# Step: collect（负责：从 json 中按 selector 收集值，输出 values.csv）
# ==============================================================================
collect:
  # 是否写 CSV 表头
  csv_write_header: true

  # 严格模式
  # - true ：遇到错误直接抛异常（runner 捕获后中断）
  # - false：失败返回 None 或跳过（按你原逻辑）
  strict_mode: false

# ==============================================================================
# Step: find_range（负责：根据 values.csv 估计区间，输出 ranges.csv）
# ==============================================================================
find_range:
  method: "cover"          # "iqr" / "mad" / "cover"
  iqr_k: 1.5
  mad_z: 3.0
  cover_pct: 0.95

# ==============================================================================
# Step: find_range_full
# ==============================================================================

# ==============================================================================
# Step: test_range（负责：区间命中检测，写回 ranges.csv 并输出统计）
# ==============================================================================
test_range:
  treat_nan_as_fail: true
  fields_mode: "range_only"

  missing_value_col_is_fail: true
  missing_range_is_fail: false

  show_top_fields: true
  top_n_fields: 5

  show_fail_details: true
  max_fail_details: 1


# ==============================================================================
# Step: generate_db_csv（负责：生成用于导入 PostgreSQL 的 5 个 CSV 文件）
# ==============================================================================
generate_db_csv:
  # JSON 文件后缀过滤
  json_suffix: "_collect.json"

  # CSV 编码
  csv_encoding: "utf-8-sig"

  # 数据库 CSV 输出目录名
  db_dirname: "db"

  # 字段缺失时的默认值
  default_value: "N/A"

  # 表结构配置：为各个 CSV 文件定义额外的列（通过 selector 提取）
  # 说明：
  # - 默认列（如 episode_id, taskid, model, filename 等）会自动生成，无需配置
  # - 只需要配置需要从 JSON 中通过 selector 提取的额外列
  # - 支持的表：episode, field, field_value, thresholds_base, thresholds_full
  table_extra_columns:
    # episode 表的额外列
    episode:
      sn: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<equipment_info>.<sn>"
      collected_at: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<collected_at>"
      # 可以继续添加更多列，例如：
      # duration_ms: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<duration_in_ms>"
      # version: ".<report>.[<ruleCode>=<metadata_raw>].<rawDataMetric>.[<name>=<metadata.json>].<rawData>.<metadata>.<ver>"
    
    # field 表的额外列（如果需要）
    # field:
    #   custom_field: "selector..."
    
    # field_value 表的额外列（如果需要）
    # field_value:
    #   custom_field: "selector..."
    
    # thresholds_base 表的额外列（如果需要）
    # thresholds_base:
    #   custom_field: "selector..."
    
    # thresholds_full 表的额外列（如果需要）
    # thresholds_full:
    #   custom_field: "selector..."


# ==============================================================================
# Step: visualize_db（负责：Plotly Dash 可视化数据库数据）
# ==============================================================================
visualize_db:
  # Dash 服务器配置
  host: "127.0.0.1"
  port: 8050
  debug: true  # 本地开发模式

  # 数据库连接配置
  db_host: "localhost"
  db_port: 5432
  db_database: "inspect"
  db_user: "openloong"
  db_password: "openloongINSPECTCONFIG"

  # 图表配置
  max_fields: 5
  chart_height: 600

  # 导出配置
  export_dir: "exports"
  export_dpi: 300

  # 兼容旧配置：metadata_selectors（已废弃，建议使用 table_extra_columns.episode）
  # 如果同时存在，会自动合并到 episode 表
  # metadata_selectors:
  #   sn: "selector..."
  #   collected_at: "selector..."

# ==============================================================================
# Step: import_db（负责：将 CSV 导入到 PostgreSQL 数据库）
# ==============================================================================
import_db:
  # 数据库连接配置
  host: "localhost"
  port: 5432
  database: "inspect"
  user: "openloong"
  password: "openloongINSPECTCONFIG"

  # 导入策略
  truncate_before_import: true  # 每次导入前清空表
  
  # schema 命名规则（支持 {model} 和 {model_lower} 占位符）
  schema_name_template: "{model_lower}"
  
  # 是否创建表（如果不存在）
  create_tables_if_missing: true
  
  # 是否导入 thresholds_full
  enable_full: true
  
  # db CSV 目录名
  db_dirname: "db"
  
  # 是否演练
  dry_run: false

  # 表结构定义：定义每个表的列名和数据类型
  # 说明：
  # - 列名必须与 CSV 文件的表头完全匹配
  # - 数据类型使用 PostgreSQL 标准类型
  # - PRIMARY KEY 标记主键
  # - 如果需要添加新列，同步修改 generate_db_csv.table_extra_columns
  table_schemas:
    # episode 表：存储 episode 基本信息
    episode:
      episode_id: "TEXT PRIMARY KEY"
      taskid: "TEXT NOT NULL"
      model: "TEXT NOT NULL"
      sn: "TEXT"
      collected_at: "TEXT"
      filename: "TEXT NOT NULL"
    
    # field 表：存储字段定义
    field:
      field_id: "INTEGER PRIMARY KEY"
      field: "TEXT NOT NULL"
      rule_code: "TEXT"
      type: "TEXT"
    
    # field_value 表：存储字段值（长格式）
    field_value:
      episode_id: "TEXT PRIMARY KEY"
      field_id: "INTEGER PRIMARY KEY"
      value: "TEXT"
    
    # thresholds_base 表：存储基础阈值
    thresholds_base:
      field: "TEXT PRIMARY KEY"
      min: "TEXT"
      max: "TEXT"
      pass_count: "TEXT"
      fail_count: "TEXT"
      pass_rate: "TEXT"
    
    # thresholds_full 表：存储完整阈值
    thresholds_full:
      field: "TEXT PRIMARY KEY"
      min: "TEXT"
      max: "TEXT"
      pass_count: "TEXT"
      fail_count: "TEXT"
      pass_rate: "TEXT"


  # 表结构定义
  # 说明：
  # - 必须与 generate_db_csv 生成的 CSV 列完全匹配（列名和顺序）
  # - 支持的数据类型：TEXT, BIGINT, INTEGER, DOUBLE PRECISION, BOOLEAN, TIMESTAMP 等
  # - PRIMARY KEY 标记：在类型后添加 "PRIMARY KEY"
  # - NOT NULL 标记：在类型后添加 "NOT NULL"
  # - 复合主键：多个列标记 PRIMARY KEY 即可
  table_schemas:
    episode:
      episode_id: "TEXT PRIMARY KEY"
      taskid: "TEXT"
      model: "TEXT"
      sn: "TEXT"
      collected_at: "TEXT"
      filename: "TEXT"
    
    field:
      field_id: "BIGINT PRIMARY KEY"
      field: "TEXT NOT NULL"
      rule_code: "TEXT"
      type: "TEXT"
    
    field_value:
      episode_id: "TEXT PRIMARY KEY"
      field_id: "BIGINT PRIMARY KEY"
      value: "TEXT"
    
    thresholds_base:
      field: "TEXT PRIMARY KEY"
      min: "TEXT"
      max: "TEXT"
      pass_count: "BIGINT"
      fail_count: "BIGINT"
      pass_rate: "DOUBLE PRECISION"
    
    thresholds_full:
      field: "TEXT PRIMARY KEY"
      min: "TEXT"
      max: "TEXT"
      pass_count: "BIGINT"
      fail_count: "BIGINT"
      pass_rate: "DOUBLE PRECISION"

# ==============================================================================
# Step: pack_csv（负责：把 ranges.csv 转成 ranges.txt）
# ==============================================================================

# ==============================================================================
# Step: build_sql（负责：把 ranges.txt 生成 update_rule_config.sql）
# ==============================================================================
build_sql:
  sql_dirname: "sql_output"
  sql_filename: "update_rule_config.sql"
  csv_output_dirname: "csv_output"
  fail_if_missing: true

# ==============================================================================
# Step: update_rule_obs（负责：把 ranges.csv 上传到 OBS 固定路径，不覆盖）
# ==============================================================================
update_rule_obs:
  # dev / prod（bucket 从 global.presets.<preset>.obs_bucket 取）
  current_preset: "prod"

# ==============================================================================
# Step: update_rule_api（负责：调用接口更新规则）
# ==============================================================================
update_rule_api:
  # 当前使用哪个预设（dev 或 prod）
  current_preset: "prod"

  # header 名：按你接口要求是 accesstoken
  access_token: "eyJhbGciOiJSUzI1NiIsImtpZCI6ImRhdGEtY29sbGVjdG9yLWNlcnQiLCJ0eXAiOiJKV1QifQ..ne9-ucYefAD62Njv6kBJu3s4zC2Mr8afyetqadKklu6vJlrVIHoWdRh_4B0Ct6Hi_avhCQQDBOc80lyyIBaq7ud84BeHP5maUjfPiv3DmBQx-fMwhe9gzAyYxJfAE4wtmnTuoS0Ga9WwXQHJyhEQHJOaGJfFwKttIlNrMKd4Eoq6wOU5hnf3Wo3yAHh1ClHdYGR8kVH03svoC2caxp4_x44ggxjo43WBqbmNhyoGbrTPKOApKNu-x5ktaNqyL8fJfT69X4BEcrLBHp3dUcfrcHsDkkNqxqvYogNHWN20-WtVr8bn66uCp-iJ6h6ledkSiq7e14MBf5CNCyOmW2AnWZ8LOOSGWpR0_F4dpt-GxzNOIZKeQKpQHIR9BrcatNzCXx_m4sk-5PJUgMl4LUgAXdhFMTHlZGoF5JgDAPC2W5z767752nuoJ1hPLkUmyAQKpzCt7bJvJaYjGhUFuT5FPPoKxa2brw3BTwbWQcjuCCfgX9-7uJbKSkwKpcWRafT85jfvEHzCI18wD333aI36CtVL9rZkyRAQdzW9k2LEPjijaDpTtqgteuKDRZZttNIgGie_vZKIoaTiUx7W0pa3EtKq7CAFcvovjuoxZpbiRabNNGlyfR9l_soGkJ9OECuqNaUH6pTo2mBqv9HWwjN6FLIg4hLvXv_iuyyOHAKE3hE"
