# 数据库配置（敏感信息）
DB_HOST=localhost
DB_PORT=5433
DB_NAME=inspect_config_db
DB_USER=inspect_user
DB_PASSWORD=inspect_password

# OBS 配置路径（根据不同环境修改）
# 上海配置
OBSUTIL_CONFIG_SHANGHAI=/home/app-dev/.obsutil_shanghai/.obsutilconfig_shanghai

# 郑州配置
OBSUTIL_CONFIG_ZHENGZHOU=/home/app-dev/.obsutil_zhengzhou/.obsutilconfig_zhengzhou

# 临时下载目录
TMP_DIR=/tmp/obs_ingest

# obsutil 可执行文件路径（如果不在 PATH 中）
# OBSUTIL_EXE=/path/to/obsutil
